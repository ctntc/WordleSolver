  <ItemGroup>
    <ProjectReference Include="..\WordleSolver.Engine\WordleSolver.Engine.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.3"/>
  </ItemGroup>

</Project>
